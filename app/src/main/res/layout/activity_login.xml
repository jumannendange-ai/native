<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <!-- Logo area -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginTop="48dp"
            android:layout_marginBottom="32dp">

            <TextView
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:background="@drawable/bg_logo"
                android:text="▶"
                android:textSize="32sp"
                android:textColor="@color/white"
                android:gravity="center"
                android:layout_gravity="center"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="JAYNES MAX TV"
                android:textSize="28sp"
                android:textColor="@color/primary"
                android:textStyle="bold"
                android:letterSpacing="0.15"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Stream · Live · Enjoy"
                android:textSize="11sp"
                android:textColor="@color/muted"
                android:letterSpacing="0.2"
                android:layout_marginTop="4dp"/>
        </LinearLayout>

        <!-- Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="22dp">

            <!-- Title -->
            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="INGIA"
                android:textSize="22sp"
                android:textColor="@color/text"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:id="@+id/tvSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Karibu tena!"
                android:textSize="13sp"
                android:textColor="@color/muted"
                android:layout_marginBottom="20dp"/>

            <!-- Error box -->
            <TextView
                android:id="@+id/tvError"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_error"
                android:textColor="#FF5577"
                android:textSize="13sp"
                android:padding="12dp"
                android:layout_marginBottom="14dp"
                android:visibility="gone"/>

            <!-- Name field (register only) -->
            <LinearLayout
                android:id="@+id/nameLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone"
                android:orientation="vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Jina Kamili"
                    android:textSize="12sp"
                    android:textColor="@color/muted"
                    android:layout_marginBottom="6dp"/>

                <EditText
                    android:id="@+id/etName"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:background="@drawable/bg_input"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:textColor="@color/text"
                    android:textColorHint="@color/muted"
                    android:hint="Jina lako kamili"
                    android:textSize="15sp"
                    android:inputType="textPersonName"
                    android:singleLine="true"/>
            </LinearLayout>

            <!-- Email -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Barua Pepe"
                android:textSize="12sp"
                android:textColor="@color/muted"
                android:layout_marginBottom="6dp"/>

            <EditText
                android:id="@+id/etEmail"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/bg_input"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:textColor="@color/text"
                android:textColorHint="@color/muted"
                android:hint="mfano@email.com"
                android:textSize="15sp"
                android:inputType="textEmailAddress"
                android:singleLine="true"
                android:layout_marginBottom="12dp"/>

            <!-- Password -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nywila"
                android:textSize="12sp"
                android:textColor="@color/muted"
                android:layout_marginBottom="6dp"/>

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginBottom="10dp">

                <EditText
                    android:id="@+id/etPassword"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_input"
                    android:paddingStart="16dp"
                    android:paddingEnd="52dp"
                    android:textColor="@color/text"
                    android:textColorHint="@color/muted"
                    android:hint="••••••••"
                    android:textSize="15sp"
                    android:inputType="textPassword"
                    android:singleLine="true"/>

                <ImageButton
                    android:id="@+id/btnEye"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_gravity="end|center_vertical"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@android:drawable/ic_menu_view"
                    android:tint="@color/muted"
                    android:contentDescription="Onyesha nywila"/>
            </FrameLayout>

            <!-- Forgot -->
            <TextView
                android:id="@+id/tvForgot"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:text="Umesahau nywila?"
                android:textSize="12sp"
                android:textColor="@color/accent"
                android:layout_marginBottom="20dp"
                android:clickable="true"
                android:focusable="true"/>

            <!-- Progress -->
            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:indeterminateTint="@color/primary"
                android:visibility="gone"
                android:layout_marginBottom="8dp"/>

            <!-- Auth Button -->
            <Button
                android:id="@+id/btnAuth"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_button"
                android:text="INGIA"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:layout_marginBottom="18dp"/>

            <!-- Toggle -->
            <TextView
                android:id="@+id/tvToggle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="Huna akaunti? Jiandikishe hapa"
                android:textSize="13sp"
                android:textColor="@color/accent"
                android:clickable="true"
                android:focusable="true"/>

        </LinearLayout>

        <!-- Bottom space -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Shida? WhatsApp: 0616393956"
            android:textSize="12sp"
            android:textColor="@color/muted"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="32dp"/>

    </LinearLayout>
</ScrollView>
