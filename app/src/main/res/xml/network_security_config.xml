<?xml version="1.0" encoding="utf-8"?>
<network-security-config>

    <!-- Ruhusu traffic yote (API server + streams) -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </base-config>

    <!-- Render.com API server — HTTPS pekee -->
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">onrender.com</domain>
        <domain includeSubdomains="true">supabase.co</domain>
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </domain-config>

    <!-- Stream sources — cleartext inaruhusiwa (HLS/DASH) -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">zimotv.com</domain>
        <domain includeSubdomains="true">bailatv.live</domain>
        <domain includeSubdomains="true">pixtvmax.com</domain>
        <domain includeSubdomains="true">dde.ct.ws</domain>
        <domain includeSubdomains="true">mq.xo.je</domain>
    </domain-config>

</network-security-config>
